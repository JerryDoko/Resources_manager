{
  "name": "resources-manager",
  "version": "0.1.0",
  "private": true,
  "description": "本地一体化资源管理器 — 漫画、条漫、小说、视频、音乐与照片，私有、离线、自动整理",
  "author": "JerryDoko",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:studio": "drizzle-kit studio",
    "resources": "bash scripts/start.sh dev",
    "resources:start": "bash scripts/start.sh start",
    "resources:web": "bash scripts/start.sh web",
    "resources:build": "bash scripts/start.sh build",
    "lm": "bash scripts/start.sh dev",
    "desktop": "node scripts/desktop.js dev",
    "electron": "electron electron/main.js",
    "pack:prepare": "node scripts/prepare-mac-pack.mjs",
    "dist:mac": "electron-builder --mac --publish never",
    "release:mac": "npm run pack:prepare && npm run dist:mac"
  },
  "main": "electron/main.js",
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "drizzle-orm": "^0.45.2",
    "iconv-lite": "^0.7.3",
    "jschardet": "^3.1.4",
    "jszip": "^3.10.1",
    "lucide-react": "^1.25.0",
    "music-metadata": "^11.14.0",
    "next": "15.1.6",
    "pdfjs-dist": "^4.10.38",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sharp": "^0.35.3",
    "tailwind-merge": "^3.6.0",
    "uuid": "^14.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@types/better-sqlite3": "^7.6.13",
    "@types/jszip": "^3.4.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/sharp": "^0.32.0",
    "@types/uuid": "^11.0.0",
    "drizzle-kit": "^0.31.10",
    "electron": "^36.4.0",
    "electron-builder": "^26.0.12",
    "eslint": "^9",
    "eslint-config-next": "15.1.6",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  },
  "build": {
    "appId": "com.jerrydoko.resourcesmanager",
    "productName": "Resources Manager",
    "copyright": "Copyright © 2026 JerryDoko",
    "directories": {
      "output": "release",
      "buildResources": "build-resources"
    },
    "afterPack": "./scripts/after-pack.cjs",
    "npmRebuild": false,
    "files": [
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [],
    "mac": {
      "category": "public.app-category.entertainment",
      "icon": "build-resources/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64"
          ]
        }
      ],
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "identity": null
    },
    "dmg": {
      "title": "Resources Manager",
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "asar": true
  }
}
